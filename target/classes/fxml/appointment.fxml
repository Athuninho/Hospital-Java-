<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="768.0" prefWidth="804.0" spacing="15.0" styleClass="content-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hms.controller.AppointmentController">
   <children>
      <Label styleClass="header-label" text="Appointment Booking">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>
      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <!-- Form Section -->
            <VBox prefWidth="350.0" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
               <children>
                  <Label text="Book/Edit Appointment" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                  
                  <GridPane hgap="10" vgap="10">
                      <columnConstraints>
                          <ColumnConstraints hgrow="SOMETIMES" minWidth="90.0" />
                          <ColumnConstraints hgrow="ALWAYS" />
                      </columnConstraints>
                      
                      <Label text="Patient:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                      <ComboBox fx:id="patientComboBox" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                      
                      <Label text="Doctor:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                      <ComboBox fx:id="doctorComboBox" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                      
                      <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                      <DatePicker fx:id="datePicker" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                      
                      <Label text="Time (HH:mm):" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                      <TextField fx:id="timeField" promptText="09:30" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                      
                      <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                      <ComboBox fx:id="statusComboBox" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  </GridPane>
                  
                  <HBox spacing="10.0" alignment="CENTER_RIGHT">
                      <Button mnemonicParsing="false" onAction="#clearFields" text="Clear" />
                      <Button mnemonicParsing="false" onAction="#handleDelete" styleClass="delete-button" text="Delete" />
                      <Button mnemonicParsing="false" onAction="#handleSave" styleClass="action-button" text="Save" />
                  </HBox>
               </children>
            </VBox>
            
            <!-- Table Section -->
            <VBox HBox.hgrow="ALWAYS" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
               <children>
                  <TableView fx:id="appointmentTable" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="idCol" prefWidth="40.0" text="ID" />
                      <TableColumn fx:id="patientCol" prefWidth="120.0" text="Patient Name" />
                      <TableColumn fx:id="doctorCol" prefWidth="120.0" text="Doctor Name" />
                      <TableColumn fx:id="dateCol" prefWidth="90.0" text="Date" />
                      <TableColumn fx:id="timeCol" prefWidth="70.0" text="Time" />
                      <TableColumn fx:id="statusCol" prefWidth="80.0" text="Status" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
