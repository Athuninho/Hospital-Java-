<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="768.0" prefWidth="804.0" spacing="15.0" styleClass="content-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hms.controller.BillingController">
   <children>
      <Label styleClass="header-label" text="Billing &amp; Invoicing">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>
      
      <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
         <children>
            <Label text="Bill Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            
            <GridPane hgap="15" vgap="10">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0" />
                </columnConstraints>
                
                <Label text="Patient:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <ComboBox fx:id="patientComboBox" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                
                <Label text="Appointment:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <ComboBox fx:id="appointmentComboBox" prefWidth="250.0" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                
                <Label text="Tax ($):" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="taxField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                
                <Label text="Discount ($):" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="discountField" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                
                <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="statusComboBox" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </GridPane>
         </children>
      </VBox>
      
      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <!-- Add Item Section -->
            <VBox prefWidth="300.0" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
               <children>
                  <Label text="Add Line Item" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                  <Label text="Description:" />
                  <TextField fx:id="descField" />
                  <Label text="Quantity:" />
                  <TextField fx:id="qtyField" />
                  <Label text="Unit Price ($):" />
                  <TextField fx:id="priceField" />
                  <Button mnemonicParsing="false" onAction="#handleAddItem" styleClass="action-button" text="Add Item" prefWidth="300" />
               </children>
            </VBox>
            
            <!-- Items Table and Summary -->
            <VBox HBox.hgrow="ALWAYS" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
               <children>
                  <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="descCol" prefWidth="200.0" text="Description" />
                      <TableColumn fx:id="qtyCol" prefWidth="75.0" text="Qty" />
                      <TableColumn fx:id="priceCol" prefWidth="100.0" text="Unit Price" />
                      <TableColumn fx:id="totalCol" prefWidth="100.0" text="Total" />
                    </columns>
                  </TableView>
                  <Button mnemonicParsing="false" onAction="#handleRemoveItem" styleClass="delete-button" text="Remove Selected Item" />
                  
                  <GridPane hgap="10" vgap="5" alignment="CENTER_RIGHT">
                      <Label text="Subtotal:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
                      <Label fx:id="subtotalLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                      
                      <Label text="Total ($):" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-font-size: 18px;" />
                      <Label fx:id="totalLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-font-size: 18px;" textFill="#27ae60" />
                  </GridPane>
                  <Button mnemonicParsing="false" onAction="#handleSaveBill" styleClass="action-button" text="Generate Bill" prefWidth="200" VBox.margin="10" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
