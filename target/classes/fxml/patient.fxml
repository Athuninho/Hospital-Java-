<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="768.0" prefWidth="804.0" spacing="15.0" styleClass="content-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hms.controller.PatientController">
   <children>
      <Label styleClass="header-label" text="Patient Registration">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>
      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <!-- Form Section -->
            <VBox prefWidth="350.0" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
               <children>
                  <Label text="Patient Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                  
                  <GridPane hgap="10" vgap="10">
                      <columnConstraints>
                          <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" />
                          <ColumnConstraints hgrow="ALWAYS" />
                      </columnConstraints>
                      
                      <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                      <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                      
                      <Label text="Age:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                      <TextField fx:id="ageField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                      
                      <Label text="Gender:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                      <ComboBox fx:id="genderComboBox" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                      
                      <Label text="Contact:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                      <TextField fx:id="contactField" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                      
                      <Label text="Blood Group:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                      <ComboBox fx:id="bloodGroupComboBox" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                      
                      <Label text="Emerg. Contact:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                      <TextField fx:id="emergencyContactField" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                      
                      <Label text="Address:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                      <TextArea fx:id="addressArea" prefRowCount="3" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                  </GridPane>
                  
                  <HBox spacing="10.0" alignment="CENTER_RIGHT">
                      <Button mnemonicParsing="false" onAction="#clearFields" text="Clear" />
                      <Button mnemonicParsing="false" onAction="#handleDelete" styleClass="delete-button" text="Delete" />
                      <Button mnemonicParsing="false" onAction="#handleSave" styleClass="action-button" text="Save" />
                  </HBox>
               </children>
            </VBox>
            
            <!-- Table Section -->
            <VBox HBox.hgrow="ALWAYS" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
               <children>
                  <HBox spacing="10.0" alignment="CENTER_LEFT">
                     <TextField fx:id="searchField" promptText="Search by Name, ID..." HBox.hgrow="ALWAYS" />
                     <Button mnemonicParsing="false" onAction="#handleSearch" styleClass="action-button" text="Search" />
                  </HBox>
                  <TableView fx:id="patientTable" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="idCol" prefWidth="50.0" text="ID" />
                      <TableColumn fx:id="nameCol" prefWidth="150.0" text="Name" />
                      <TableColumn fx:id="ageCol" prefWidth="50.0" text="Age" />
                      <TableColumn fx:id="genderCol" prefWidth="75.0" text="Gender" />
                      <TableColumn fx:id="contactCol" prefWidth="100.0" text="Contact" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
