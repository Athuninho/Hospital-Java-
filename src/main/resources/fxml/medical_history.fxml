<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="768.0" prefWidth="804.0" spacing="15.0" styleClass="content-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hms.controller.MedicalHistoryController">
   <children>
      <Label styleClass="header-label" text="Medical History">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>
      
      <HBox spacing="10.0" alignment="CENTER_LEFT">
          <Label text="Select Patient:" style="-fx-font-weight: bold;" />
          <ComboBox fx:id="patientComboBox" prefWidth="300.0" />
      </HBox>
      
      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <!-- Form Section -->
            <VBox prefWidth="400.0" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
               <children>
                  <Label text="Add/View Record" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                  
                  <Label text="Related Appointment (Optional):" />
                  <ComboBox fx:id="appointmentComboBox" prefWidth="380.0" />
                  
                  <Label text="Diagnoses:" />
                  <TextArea fx:id="diagnosesArea" prefRowCount="3" wrapText="true" />
                  
                  <Label text="Prescriptions:" />
                  <TextArea fx:id="prescriptionsArea" prefRowCount="3" wrapText="true" />
                  
                  <Label text="Allergies:" />
                  <TextArea fx:id="allergiesArea" prefRowCount="2" wrapText="true" />
                  
                  <Label text="Test Results:" />
                  <TextArea fx:id="testResultsArea" prefRowCount="3" wrapText="true" />
                  
                  <HBox spacing="10.0" alignment="CENTER_RIGHT">
                      <Button mnemonicParsing="false" onAction="#handleClear" text="Clear" />
                      <Button mnemonicParsing="false" onAction="#handleSave" styleClass="action-button" text="Save Record" />
                  </HBox>
               </children>
            </VBox>
            
            <!-- Table Section -->
            <VBox HBox.hgrow="ALWAYS" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
               <children>
                  <Label text="Patient History Timeline" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                  <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="dateCol" prefWidth="120.0" text="Date Recorded" />
                      <TableColumn fx:id="diagnosesCol" prefWidth="120.0" text="Diagnoses" />
                      <TableColumn fx:id="prescriptionsCol" prefWidth="120.0" text="Prescriptions" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
